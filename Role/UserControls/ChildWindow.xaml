<Window x:Class="RoleDDNG.Role.UserControls.ChildWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:RoleDDNG.Role.UserControls"
    mc:Ignorable="d"
    MinHeight="300" MinWidth="400"
    ResizeMode="CanResizeWithGrip"
    Name="ChildWindowWin" WindowStartupLocation="CenterOwner" SourceInitialized="ChildWindowWin_SourceInitialized">
    <Window.Style>
        <Style BasedOn="{StaticResource {x:Type Window}}" TargetType="Window" />
    </Window.Style>
    <Grid>
        <ContentControl Name="ContentControl" Content="{Binding ElementName=ChildWindowWin, Path=DataContext}" />
    </Grid>
</Window>